# PostgreSQL and TimescaleDB
POSTGRES_PASSWORD=your_password_here

# ClickHouse
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_password_here

# QuestDB (uses PostgreSQL wire protocol; set a password if auth is enabled)
QDB_PASSWORD=

# InfluxDB 2
INFLUXDB_ADMIN_PASSWORD=your_password_here
INFLUXDB_TOKEN=your_token_here

# InfluxDB 3 Enterprise — disabled by default (see README)
# INFLUXDB3_LICENSE_EMAIL=your_email@example.com
# INFLUXDB3_TOKEN=

# Web UI
APP_USER=admin
APP_PASS=your_password_here

# Optional: memory limit for containers (default 20G)
MEM_LIMIT=20G
